# .env.example
# CodeVerdict Configuration ⚖️
# Copy this file to .env and update with your values

# Application
APP_NAME=CodeVerdict
APP_VERSION=1.0.0
APP_DESCRIPTION=Where AI Code Stands Trial

# MLflow
MLFLOW_TRACKING_URI=sqlite:///mlflow.db
MLFLOW_REGISTRY_URI=sqlite:///mlflow.db

# Argilla
ARGILLA_API_URL=http://localhost:6900
ARGILLA_API_KEY=codeverdict.apikey

# Model APIs (Optional - for AI-as-judge)
OPENAI_API_KEY=your_openai_key_here
ANTHROPIC_API_KEY=your_anthropic_key_here
HUGGINGFACE_TOKEN=your_hf_token_here

# Evaluation Settings
AUTO_EVAL_THRESHOLD=0.8
MANUAL_REVIEW_SAMPLE_RATE=0.5
MIN_MANUAL_REVIEWS=10
MAX_CONCURRENT_EVALUATIONS=50

# Security
ENABLE_SECURITY_SCAN=true
ENABLE_BIAS_DETECTION=true

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json